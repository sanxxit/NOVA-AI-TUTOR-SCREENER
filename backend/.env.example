# ── Required ──────────────────────────────────────────────────────────────────

# PostgreSQL connection string (Supabase, Neon, or any Postgres provider)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Groq API key for LLM inference (Maya's responses + scoring)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── TTS ───────────────────────────────────────────────────────────────────────

# Sarvam AI key for primary TTS (Indian-accent voice).
# If omitted, falls back to local Piper binary.
SARVAM_API_KEY=your_sarvam_key_here

# ── Email notifications (Resend) ──────────────────────────────────────────────

# Resend API key — leave blank to disable emails entirely
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Address that receives the "candidate passed" admin alert
ADMIN_EMAIL=recruiter@yourdomain.com

# Verified sender address in your Resend account
FROM_EMAIL=noreply@yourdomain.com

# ── Admin dashboard ───────────────────────────────────────────────────────────

ADMIN_PASSWORD=choose-a-strong-password
JWT_SECRET=choose-a-long-random-secret

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Supports wildcard subdomain entries (e.g. *.vercel.app) for Vercel previews.
ALLOWED_ORIGINS=https://your-app.vercel.app,*.vercel.app,https://yourdomain.com
